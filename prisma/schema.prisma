generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  schemas  = ["open_social"]
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  profile   Profile?
  posts     Post[]

  @@schema("open_social")
}

model Profile {
  id        String   @id @default(uuid())
  firstname String
  lastname  String
  nickname  String
  sex       Sex
  userId    String   @unique
  public    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])

  @@schema("open_social")
}

model Post {
  id        String   @id @default(uuid())
  content   String
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])

  @@schema("open_social")
}

enum Sex {
  male
  female

  @@schema("open_social")
}
