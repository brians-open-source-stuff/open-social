generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  schemas  = ["dev"]
}

model User {
  id        String     @id @default(uuid())
  email     String     @unique
  password  String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  profile   Profile?
  posts     Post[]
  likes     PostLike[]

  @@schema("dev")
}

model Profile {
  id            String   @id @default(uuid())
  firstname     String
  lastname      String
  nickname      String?
  slug          String?
  sex           Sex
  userId        String   @unique
  avatarMediaId String?  @unique
  public        Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id])
  avatarMedia   Media?   @relation("ProfileAvatar", fields: [avatarMediaId], references: [id])

  @@schema("dev")
}

enum Sex {
  male
  female

  @@schema("dev")
}

model Post {
  id        String      @id @default(uuid())
  content   String
  userId    String
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  user      User        @relation(fields: [userId], references: [id])
  media     PostMedia[]
  likes     PostLike[]

  @@schema("dev")
}

model PostLike {
  id        String   @id @default(uuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([postId])
  @@index([userId])
  @@schema("dev")
}

model Media {
  id         String   @id @default(uuid())
  url        String
  mimeType   String
  bytes      Int?
  width      Int?
  height     Int?
  durationMs Int?
  altText    String?
  public     Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  userId     String

  avatarFor Profile?    @relation("ProfileAvatar")
  post      PostMedia[]

  @@schema("dev")
}

model PostMedia {
  id        String   @id @default(uuid())
  postId    String
  mediaId   String
  sortOrder Int      @default(0)
  caption   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  post  Post  @relation(fields: [postId], references: [id], onDelete: Cascade)
  media Media @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@unique([postId, mediaId])
  @@index([postId, sortOrder])
  @@schema("dev")
}
